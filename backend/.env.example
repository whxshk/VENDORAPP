# Database - MongoDB Atlas connection string
# Replace with your actual MongoDB Atlas connection string
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# JWT (required)
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_REFRESH_TOKEN_SECRET="dev-refresh-secret-change-in-production"

# Optional
NODE_ENV=development
PORT=3001
NATS_URL=nats://localhost:4222
# CORS — comma-separated list of allowed origins (no trailing slashes).
# Local dev: *
# Production (Azure App Service env var):
#   https://merchant.sharkband.cloud,https://app.sharkband.cloud,https://proud-forest-0fba2710f.1.azurestaticapps.net,https://purple-ground-02e4fe00f.6.azurestaticapps.net
CORS_ORIGIN=*

# Merchant dashboard URL — used in staff invite email links and merchant password reset emails.
# Production: https://merchant.sharkband.cloud
FRONTEND_URL=http://localhost:5173

# Customer app URL — used in customer password reset emails.
# Production: https://app.sharkband.cloud
CUSTOMER_APP_URL=http://localhost:5174

# SMTP (required for staff invite emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="SharkBand <no-reply@example.com>"

# Google Maps — required for address geocoding
# Enable "Geocoding API" at https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
