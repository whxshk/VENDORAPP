VITE_DEMO_MODE=false
VITE_ENVIRONMENT=PILOT
VITE_API_BASE_URL=/api/v1
VITE_BACKEND_ORIGIN=http://localhost:3001

# Google Maps — required for address autocomplete on sign-up and settings
