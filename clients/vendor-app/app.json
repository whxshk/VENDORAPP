{
  "expo": {
    "name": "SharkBand",
    "slug": "sharkband-customer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sharkband",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1931"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sharkband.customerapp",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.sharkband.customerapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1931"
      }
    },
    "extra": {
      "apiBaseUrl": "https://api.sharkband.cloud/api/v1",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1931",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ]
  }
}
