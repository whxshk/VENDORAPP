{
  "name": "streamshelf",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"next dev -p 3100\" \"wait-on tcp:3100 && npm run electron:dev\"",
    "dev:bridge": "ts-node middleware/server.ts",
    "electron:dev": "electron electron/bootstrap.cjs",
    "build": "next build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "start": "concurrently -k \"next start -p 3100\" \"wait-on tcp:3100 && electron .\"",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "express": "^4.22.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.34.3",
    "next": "^15.2.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.51.0",
    "playwright-extra": "^4.3.6",
    "prisma": "^6.5.0",
    "puppeteer-extra-plugin-recaptcha": "^3.6.8",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stremio-addon-sdk": "^1.6.10",
    "tailwind-merge": "^3.0.2",
    "ts-node": "^10.9.2",
    "video.js": "^8.21.0",
    "videojs-contrib-hls": "^5.15.0",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/webtorrent": "^0.110.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^30.5.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2",
    "wait-on": "^8.0.2"
  }
}
